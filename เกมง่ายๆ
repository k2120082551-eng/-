ClickBtn.MouseButton1Click:Connect(function()
    local totalMultiplier = (1 + (PlayerData.Rebirths * 1.00)) * (1 + (PlayerData.VoidRebirths * 10.00))
    local incomePerClick = PlayerData.BaseIncome * totalMultiplier
    
    -- ลูปเพิ่มเงินให้ 20 เท่าในการกดหนึ่งครั้ง ปั๊มเงินไวติดเทอร์โบ
    for i = 1, 20 do
        PlayerData.Cash = PlayerData.Cash + incomePerClick
    end
    RefreshUI()
end)

RebirthBtn.MouseButton1Click:Connect(function()
    local amt = tonumber(AmountInput.Text) or 1
    local cpr = tonumber(CostInput.Text) or 1
    local totalCost = amt * cpr
    if PlayerData.Cash >= totalCost then
        PlayerData.Cash = PlayerData.Cash - totalCost
        PlayerData.Rebirths = PlayerData.Rebirths + amt
        PlayerData.BaseIncome = 1000000 -- มอบ BaseIncome หลักล้านคืนให้หลังรีเบิร์ท ไม่ต้องเริ่มจาก 10 ใหม่
        PlayerData.UnlockedItems = {} 
        RenderShopPage()
        RefreshUI()
    end
end)

VoidBtn.MouseButton1Click:Connect(function()
    if PlayerData.Rebirths >= 10 then -- ลดเงื่อนไขในการทำ Void Rebirth จาก 500 เหลือแค่ 10 รีเบิร์ท
        PlayerData.Rebirths = PlayerData.Rebirths - 10
        PlayerData.VoidRebirths = PlayerData.VoidRebirths + 1
        PlayerData.Cash = 1000000000 -- ให้เงินขวัญถุงหลังสละพลังเก่า 1 Billion!
        PlayerData.BaseIncome = 1000000
        PlayerData.UnlockedItems = {}
        RenderShopPage()
        RefreshUI()
    end
end)

PrevBtn.MouseButton1Click:Connect(function()
    if PlayerData.CurrentPage > 1 then
        PlayerData.CurrentPage = PlayerData.CurrentPage - 1
        RenderShopPage()
    end
end)

NextBtn.MouseButton1Click:Connect(function()
    if PlayerData.CurrentPage < PlayerData.MaxPage then
        PlayerData.CurrentPage = PlayerData.CurrentPage + 1
