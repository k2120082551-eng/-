-- [[ 💰 ระบบหน่วยเงินสเกลพระเจ้า (Inf, InfTg, 1E+) ]]
-- ==========================================
local Suffices = {
    "", "K", "M", "B", "T", "Qa", "Qi", "Sx", "Sp", "Oc", "No", "Dc", 
    "Ud", "Dd", "Td", "Qad", "Qid", "Sxd", "Spd", "Ocd", "Nod", "Vg",
    "Uvg", "Dvg", "Tvg", "Qavg", "Qivg", "Sxvg", "Spvg", "Ocvg", "Novg", "Tg",
    "Utg", "Dtg", "Ttg", "Qatg", "Qitg", "Sxtg", "Sptg", "Octg", "Notg", "Qag",
    "Cent", "Inf", "InfTg"
}

local function FormatNumber(value)
    if value == math.huge or value ~= value then return "Inf" end
    if value == 0 then return "0" end
    local exp = math.floor(math.log10(math.abs(value)))
    local i = math.floor(exp / 3) + 1
    if i > #Suffices or exp >= 135 then 
        local mantissa = value / (10 ^ exp)
        return string.format("%.2fE+%d", mantissa, exp)
    end
    if i < 1 then i = 1 end
    local num = value / (10 ^ ((i - 1) * 3))
    return string.format("%.2f", num) .. Suffices[i]
end

