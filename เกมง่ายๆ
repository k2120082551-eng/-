local Prefixes = {"โรงงาน", "สถานีวิจัย", "เครื่องแยก", "เตาหลอม", "มิติมหาเทพ", "ห้องแล็บ", "แท่นสกัด", "เครื่องเร่ง", "วงแหวน", "ป้อมปราการ", "อาณาจักร", "ระบบสุริยะ", "แกนกลาง", "กลุ่มดาว", "โครงข่าย", "เทวสถาน", "หอคอย", "ประตูมิติ", "หลุมดำ", "เนบิวลา"}
local Cores = {"มะนาว", "กรดซิทริก", "เปลือกเลมอน", "น้ำมะนาวเข้มข้น", "สารสกัดสีเหลือง", "อะตอมมะนาว", "ปฏิสสารเลมอน", "นาโนบอตเปรี้ยว", "พลังงานความหวาน", "คลื่นความถี่มะนาว", "รากแก้วเลมอน", "รังสีควอนตัมเลมอน", "แร่เลมอนเนียม", "พลาสม่ามะนาว"}
local Suffixes = {"โลก", "พันล้าน", "ข้ามมิติ", "จักรวาล", "สูงสุด", "บิ๊กแบง", "ไร้ขีดจำกัด", "ระดับโมเลกุล", "นิวเคลียร์", "ความเร็วแสง", "ยุคอวกาศ", "นิรันดร์", "ไซเบอร์เนติกส์", "ความว่างเปล่า", "พหุจักรวาล", "อนันตกาล"}

local function GetItemData(index)
    if index == 1 then return {Name = "เครื่องคั้นมะนาวมือถือ", Cost = 250, IncomePlus = 250000} -- บัฟรายได้ร้านค้าเพิ่ม 10,000 เท่า
    elseif index == 2 then return {Name = "มีดหั่นมะนาวสเตนเลส", Cost = 1200, IncomePlus = 1300000}
    elseif index == 3 then return {Name = "เขียงไม้คัดเกรด", Cost = 5500, IncomePlus = 6000000}
    elseif index == 4 then return {Name = "คราดเก็บมะนาวเหล็กกล้า", Cost = 24000, IncomePlus = 28000000}
    elseif index == 5 then return {Name = "ตะกร้าสานติดล้อ", Cost = 110000, IncomePlus = 140000000}
    end

    -- ชิ้นที่ 6 ขึ้นไปคำนวณแบบทวีคูณเร่งด่วน บัฟเพิ่มให้หาเงินง่ายขึ้นมหาศาล
    local generatedCost = 110000 * math.pow(1.01, index - 5) -- ลดราคาตัวคูณลงเพื่อให้ซื้อได้ง่ายขึ้น
    local generatedIncome = 140000000 * math.pow(1.05, index - 5) -- เพิ่มรายได้แบบก้าวกระโดด

    local pIdx = ((index + 3) % #Prefixes) + 1
    local cIdx = ((index * 7) % #Cores) + 1
    local sIdx = ((index + 13) % #Suffixes) + 1

    local icon = "🏭 "
    if index > 8000 then icon = "🔱 "
    elseif index > 5000 then icon = "👑 "
    elseif index > 2000 then icon = "🌌 "
    elseif index > 500 then icon = "🌀 " end

    local uniqueName = string.format("%s%s%s%s [Lv.%d]", icon, Prefixes[pIdx], Cores[cIdx], Suffixes[sIdx], index)
    return {Name = uniqueName, Cost = generatedCost, IncomePlus = generatedIncome}
end

