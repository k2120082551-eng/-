local function RefreshUI()
    -- บัฟตัวคูณจาก Rebirth และ VoidRebirth ให้แรงขึ้น 100 เท่า!
    local totalMultiplier = (1 + (PlayerData.Rebirths * 1.00)) * (1 + (PlayerData.VoidRebirths * 10.00))
    CashLabel.Text = "Money: $" .. FormatNumber(PlayerData.Cash)
    RebirthLabel.Text = "Rebirths: " .. FormatNumber(PlayerData.Rebirths)
    VoidLabel.Text = "Void Rebirths: " .. FormatNumber(PlayerData.VoidRebirths)
    MultiLabel.Text = "Income/Click: " .. FormatNumber(PlayerData.BaseIncome * totalMultiplier)
end

local function RenderShopPage()
    for _, child in ipairs(ItemListFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    PageLabel.Text = string.format("หน้า %d / %d (ไอเทมลำดับที่ %d - %d)", PlayerData.CurrentPage, PlayerData.MaxPage, (PlayerData.CurrentPage-1)*10 + 1, PlayerData.CurrentPage*10)
    
    local startIdx = (PlayerData.CurrentPage - 1) * 10 + 1
    local endIdx = startIdx + 9
    
    for index = startIdx, endIdx do
        local itemData = GetItemData(index)
        
        local ItemFrame = Instance.new("Frame")
        ItemFrame.Size = UDim2.new(1, -5, 0, 42)
        ItemFrame.BackgroundColor3 = Color3.fromRGB(33, 33, 39)
        ItemFrame.Parent = ItemListFrame
        Instance.new("UICorner", ItemFrame)
        
        local ItemInfo = Instance.new("TextLabel")
        ItemInfo.Size = UDim2.new(0.68, 0, 1, 0)
        ItemInfo.Position = UDim2.new(0, 10, 0, 0)
        ItemInfo.BackgroundTransparency = 1
        ItemInfo.Text = string.format("%s\n⚡ +%s / คลิก", itemData.Name, FormatNumber(itemData.IncomePlus))
        ItemInfo.TextColor3 = Color3.fromRGB(240, 240, 240)
        ItemInfo.TextSize = 10
        ItemInfo.TextXAlignment = Enum.TextXAlignment.Left
        ItemInfo.Parent = ItemFrame
        
        local BuyBtn = Instance.new("TextButton")
        BuyBtn.Size = UDim2.new(0.28, 0, 0, 30)
        BuyBtn.Position = UDim2.new(0.72, -5, 0, 6)
        BuyBtn.Parent = ItemFrame
        Instance.new("UICorner", BuyBtn)
        
        if PlayerData.UnlockedItems[index] then
            BuyBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
            BuyBtn.Text = "ปลดล็อกแล้ว"
            BuyBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
            BuyBtn.TextSize = 9
        else
            BuyBtn.BackgroundColor3 = Color3.fromRGB(45, 140, 45)
            BuyBtn.Text = "ซื้อ\n$" .. FormatNumber(itemData.Cost)
            BuyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            BuyBtn.TextSize = 9
            BuyBtn.Font = Enum.Font.SourceSansBold
            
            BuyBtn.MouseButton1Click:Connect(function()
                if PlayerData.Cash >= itemData.Cost and not PlayerData.UnlockedItems[index] then
                    PlayerData.Cash = PlayerData.Cash - itemData.Cost
                    PlayerData.BaseIncome = PlayerData.BaseIncome + itemData.IncomePlus
                    PlayerData.UnlockedItems[index] = true
                    BuyBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                    BuyBtn.Text = "ปลดล็อกแล้ว"
                    BuyBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
                    RefreshUI()
                end
            end)
        end
    end
end

