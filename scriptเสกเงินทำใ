-- 1. ปุ่มรันสคริปต์ (Execute Button)
local ExecBtn = Instance.new("TextButton")
ExecBtn.Size = UDim2.new(0, 130, 1, 0)
ExecBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 80)
ExecBtn.Text = "▶ รันสคริปต์"
ExecBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ExecBtn.TextSize = 14
ExecBtn.Font = Enum.Font.SourceSansBold
ExecBtn.LayoutOrder = 1
ExecBtn.Parent = ButtonFrame
Instance.new("UICorner", ExecBtn).CornerRadius = UDim.new(0, 6)

ExecBtn.MouseButton1Click:Connect(function()
    -- ใช้ฟังก์ชัน loadstring ในการรันโค้ดที่พิมพ์อยู่ในช่อง TextBox
    local code = TextBox.Text
    local success, err = pcall(function()
        local func = loadstring(code)
        if func then
            spawn(func)
        else
            warn("สคริปต์มีข้อผิดพลาดในโครงสร้าง!")
        end
    end)
    if not success then
        warn("ไม่สามารถรันได้: " .. tostring(err))
    end
end)

