ClickBtn.MouseButton1Click:Connect(function()
    local cash = LocalPlayer.leaderstats.Cash
    local currentReb = LocalPlayer.leaderstats.Rebirths.Value
    local currentVReb = LocalPlayer.leaderstats.VoidRebirths.Value
    
    local rebMultiplier = 1 + (currentReb * 0.01)
    local voidMultiplier = 1 + (currentVReb * 1.00)
    local totalMultiplier = rebMultiplier * voidMultiplier
    
    -- รับเงินพื้นฐานจากไอเทมที่เรามี คูณด้วยระบบเกิดใหม่ทั้งหมด
    cash.Value = cash.Value + (LocalPlayer.BaseIncome.Value * totalMultiplier)
end)

