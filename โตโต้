-- อัปเดตข้อมูลตัวเลขแบบ Realtime
spawn(function()
    while wait(0.1) do
        pcall(function()
            local currentCash = LocalPlayer.leaderstats.Cash.Value
            local currentReb = LocalPlayer.leaderstats.Rebirths.Value
            local currentVReb = LocalPlayer.leaderstats.VoidRebirths.Value
            
            -- คำนวณตัวคูณ: 1 Rebirth = +1% (x0.01), 1 Void Rebirth = +100% (x1.00)
            local rebMultiplier = 1 + (currentReb * 0.01)
            local voidMultiplier = 1 + (currentVReb * 1.00)
            local finalMulti = rebMultiplier * voidMultiplier

            CashLabel.Text = "เงิน: " .. string.format("%.1f", currentCash) .. " บาท"
            RebirthLabel.Text = "เกิดใหม่: " .. currentReb .. " ครั้ง"
            VoidLabel.Text = "Void เกิดใหม่: " .. currentVReb .. " ครั้ง"
            MultiLabel.Text = "ตัวคูณเงิน: x" .. string.format("%.2f", finalMulti)
        end)
    end
end)

